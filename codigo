//parte 1 de cadastro
algoritmo "Primeiro Programa"

var
  resposta:caractere
  nome: caractere
  cargo: caractere
  salario:caractere
  data:caractere
  contador:inteiro
inicio
  escreval("Escolha uma das opçoes a seguir 1- Cadastrar funcionarios; 2- Pequise pelo nome; 3- Exibir todos os funcionarios; 4- sair do programa")
  leia(resposta)
  se 1 entao
    para contador de 1 ate 10 passo 1 faca
      escreval("Digite o nome do funcionário: ")
      leia(nome)
      escreval("Digite o cargo do funcionário: ")
      leia(cargo)
      escreval("Digite o salario do funcionário: ")
      leia(salario)
      escreval("Digite a data de adimissão do funcionário: ")
      leia(data)
    fimpara
  fimse
 
fimalgoritmo

//parte de sair do programa 
